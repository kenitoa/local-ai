<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>OpenAI</id>
    <version>2.10.0</version>
    <authors>OpenAI</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>OpenAI.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/openai/openai-dotnet/tree/OpenAI_2.10.0</projectUrl>
    <description>The official .NET library for the OpenAI service API.</description>
    <releaseNotes>https://github.com/openai/openai-dotnet/blob/OpenAI_2.10.0/CHANGELOG.md</releaseNotes>
    <copyright>Copyright (c) 2026 OpenAI (https://openai.com)</copyright>
    <tags>OpenAI openai-dotnet ChatGPT Dall-E</tags>
    <repository type="git" url="https://github.com/openai/openai-dotnet" commit="edc1b51f9138375a16fc078b9ce175de76529136" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="System.ClientModel" version="1.10.0" exclude="Build,Analyzers" />
        <dependency id="System.Net.ServerSentEvents" version="10.0.2" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="System.ClientModel" version="1.10.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.ClientModel" version="1.10.0" exclude="Build,Analyzers" />
        <dependency id="System.Diagnostics.DiagnosticSource" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="System.Net.ServerSentEvents" version="10.0.2" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>