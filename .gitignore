# 환경 파일
.env
.env.*
!.env.example

# 데이터 / 모델 / 로그 (대용량, 민감)
# 사용자가 만든 산출물은 무시하되, 표준 디렉토리 구조(.gitkeep)는 유지한다.
data/**/*
!data/**/
!data/**/.gitkeep
models/*
!models/.gitkeep
logs/**/*
!logs/**/.gitkeep

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/
dist/
build/

# Build artifacts
*.exe
