# =====================================================
# local-ai 프로젝트 환경 변수 (.env.example)
# 실제 사용 시 .env 파일로 복사 후 값을 채워주세요.
#   PowerShell:  Copy-Item .env.example .env
# =====================================================

# ---------- 공통 ----------
PROJECT_NAME=local-ai
TZ=Asia/Seoul
COMPOSE_PROJECT_NAME=local-ai

# ---------- 경로 (호스트) ----------
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# ---------- 포트 매핑 ----------
WEB_UI_PORT=3000
BACKEND_PORT=8000
MODEL_SERVER_PORT=8001
VISION_SERVER_PORT=8002
EMBEDDING_SERVER_PORT=8003
LANGUAGE_WORKER_PORT=8004
HARDWARE_DETECTOR_PORT=8005
MYSQL_PORT=3306

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=localai_db
MYSQL_USER=localai
MYSQL_PASSWORD=change_me_user
MYSQL_HOST=mysql

# ---------- Backend ----------
BACKEND_SECRET_KEY=please_change_me
BACKEND_LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- 모델 서버 ----------
MODEL_SERVER_DEVICE=auto      # auto | cpu | cuda | mps
DEFAULT_LLM_MODEL=qwen2.5-7b-instruct
DEFAULT_VISION_MODEL=llava-1.6
DEFAULT_EMBEDDING_MODEL=bge-m3

# ---------- 로깅 ----------
LOG_LEVEL=INFO
LOG_ROTATION=daily            # daily | size
LOG_RETENTION_DAYS=14
