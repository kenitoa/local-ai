APP_ENV=local
AI_DEVICE=cpu
LLM_BACKEND=llama_cpp
MODEL_BACKEND=cpu
MODEL_PATH=/models
LLM_MODEL=local-code-model
LLAMA_CPP_MODEL_PATH=/models/gguf/code-model-q4.gguf
LLAMA_CPP_N_CTX=8192
LLAMA_CPP_N_THREADS=8
LLAMA_CPP_N_GPU_LAYERS=0
VLLM_MODEL_PATH=/models/base/code-model
VLLM_TENSOR_PARALLEL_SIZE=1
BASE_MODEL_PATH=/models/base/code-model
LORA_ENABLED=0
LORA_ADAPTER_NAME=code-optimizer-lora
LORA_ADAPTER_PATH=/models/adapters/code-optimizer-lora
LORA_MODEL_NAME=code-optimizer-lora
HF_HOME=/models/huggingface
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL_PATH=/models/embeddings/code-search
EMBEDDING_DIMENSION=384
