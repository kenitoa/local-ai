# =====================================================
# local-ai 프로젝트 환경 변수 (.env.example)
# 실제 사용 시 .env 파일로 복사 후 값을 채워주세요.
#   PowerShell:  Copy-Item .env.example .env
# =====================================================

# ---------- 공통 ----------
PROJECT_NAME=local-ai
TZ=Asia/Seoul
COMPOSE_PROJECT_NAME=local-ai

# ---------- 경로 (호스트) ----------
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# ---------- 포트 매핑 ----------
WEB_UI_PORT=3000
BACKEND_PORT=8000
MODEL_SERVER_PORT=8001
VISION_SERVER_PORT=8002
EMBEDDING_SERVER_PORT=8003
LANGUAGE_WORKER_PORT=8004
HARDWARE_DETECTOR_PORT=8005
MYSQL_PORT=3306

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=localai_db
MYSQL_USER=localai
MYSQL_PASSWORD=change_me_user
MYSQL_HOST=mysql

# ---------- DB 커넥션 풀 (SQLAlchemy QueuePool) ----------
# 단일 사용자/소규모 환경 기준의 안전한 기본값.
# 동시 요청이 늘어나면 DB_MAX_OVERFLOW 부터 늘리세요.
#   - 동시 사용자 1~2명         : pool=5,  overflow=10  (기본)
#   - 동시 사용자 5~10명        : pool=10, overflow=20
#   - 다중 사용자/팀 환경       : pool=20, overflow=40
# MySQL 측 max_connections (기본 151) 의 70% 이내로 유지하세요.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SEC=1800
DB_POOL_TIMEOUT_SEC=30
# 1 로 설정하면 모든 SQL 을 로그에 출력 (디버그 전용, 운영 OFF).
DB_ECHO=0

# ---------- Backend ----------
BACKEND_SECRET_KEY=please_change_me
# 단일 API 키 인증
#   - 값을 비워두면 인증이 비활성화됩니다(개발 편의).
#   - 운영엔 반드시 강력한 랜덤 값을 설정하세요(예: 64자 base64).
#   - PowerShell: [Convert]::ToBase64String([byte[]](1..48 | ForEach-Object { Get-Random -Maximum 256 }))
BACKEND_LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- 모델 서버 (자체 학습형 / 로컬 전용) ----------
# 이 프로젝트는 외부 사전학습 모델을 받아 그대로 쓰지 않습니다.
# 콜드스타트용 베이스 1개만 1회 다운로드하고, 이후 모든 모델은
# 사용자 데이터로 직접 fine-tune 하여 ./models/local/ 아래에 저장됩니다.
#
# GPU 사용 안내:
#   - NVIDIA GPU + nvidia-container-toolkit 가 설치되어 있다면 cuda 권장.
#   - GPU 가 없으면 cpu 또는 auto.
MODEL_SERVER_DEVICE=cuda         # auto | cpu | cuda | mps

# 콜드스타트 베이스 (유일하게 외부에서 받는 모델, 약 1B 파라미터)
COLD_START_BASE_ID=Qwen/Qwen2.5-Coder-1.5B
COLD_START_BASE_PARAMS_B=1.5
BOOTSTRAP_BASE_ID=Qwen/Qwen2.5-Coder-1.5B   # 컨테이너에서 참조하는 동일 ID
BOOTSTRAP_ALLOW_DOWNLOAD=1                  # 0 으로 두면 콜드스타트조차 차단(완전 오프라인 설치)

# 학습/추론 시 model-server 가 backend plan 을 받지 못했을 때 사용하는 폴백
LOCAL_CHECKPOINT=self/cold-start
LLM_N_CTX=4096
LLM_N_BATCH=256
LLM_N_THREADS=4
# GPU 오프로딩 레이어 수 (0=CPU만, -1=가능한 모든 레이어를 GPU로).
# NVIDIA GPU 사용 시 -1 권장. VRAM 부족하면 20~32 정도로 낮추세요.
LLM_N_GPU_LAYERS=-1
LLM_MAX_CONCURRENCY=1

# ---------- 로깅 ----------
LOG_LEVEL=INFO
LOG_ROTATION=daily            # daily | size
LOG_RETENTION_DAYS=7          # 7일 지난 로그 자동 삭제 (scripts/maintenance.ps1)

# ---------- 데이터 보존 정책 ----------
# 사용자 데이터(이미지/코드/답변/임베딩) 중 mtime 이 N일 이상 지난 항목을
# data/archive/<YYYY-MM>/ 하위로 이동(보관 처리). 0 이면 비활성.
DATA_RETENTION_DAYS=30
# archive 디렉터리 내에서 추가로 N일 지나면 영구 삭제 (0 이면 영구 보관).
ARCHIVE_RETENTION_DAYS=0

# ---------- DB 백업 ----------
# 로컬 mysqldump 백업 보존 일수 (scripts/db_backup.ps1).
DB_BACKUP_RETENTION_DAYS=14
DB_BACKUP_DIR=./data/db_backups
