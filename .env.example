# =====================================================
# local-ai 프로젝트 환경 변수 (.env.example)
# 실제 사용 시 .env 파일로 복사 후 값을 채워주세요.
#   PowerShell:  Copy-Item .env.example .env
# =====================================================

# ---------- 공통 ----------
PROJECT_NAME=local-ai
TZ=Asia/Seoul
COMPOSE_PROJECT_NAME=local-ai

# ---------- 경로 (호스트) ----------
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# ---------- 포트 매핑 ----------
WEB_UI_PORT=3000
BACKEND_PORT=8000
MODEL_SERVER_PORT=8001
VISION_SERVER_PORT=8002
EMBEDDING_SERVER_PORT=8003
LANGUAGE_WORKER_PORT=8004
HARDWARE_DETECTOR_PORT=8005
MYSQL_PORT=3306

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=localai_db
MYSQL_USER=localai
MYSQL_PASSWORD=change_me_user
MYSQL_HOST=mysql

# ---------- Backend ----------
BACKEND_SECRET_KEY=please_change_me
BACKEND_LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- 모델 서버 (자체 학습형 / 로컬 전용) ----------
# 이 프로젝트는 외부 사전학습 모델을 받아 그대로 쓰지 않습니다.
# 콜드스타트용 베이스 1개만 1회 다운로드하고, 이후 모든 모델은
# 사용자 데이터로 직접 fine-tune 하여 ./models/local/ 아래에 저장됩니다.
MODEL_SERVER_DEVICE=auto         # auto | cpu | cuda | mps

# 콜드스타트 베이스 (유일하게 외부에서 받는 모델, 약 1B 파라미터)
COLD_START_BASE_ID=Qwen/Qwen2.5-Coder-1.5B
COLD_START_BASE_PARAMS_B=1.5
BOOTSTRAP_BASE_ID=Qwen/Qwen2.5-Coder-1.5B   # 컨테이너에서 참조하는 동일 ID
BOOTSTRAP_ALLOW_DOWNLOAD=1                  # 0 으로 두면 콜드스타트조차 차단(완전 오프라인 설치)

# 학습/추론 시 model-server 가 backend plan 을 받지 못했을 때 사용하는 폴백
LOCAL_CHECKPOINT=self/cold-start
LLM_N_CTX=4096
LLM_N_BATCH=256
LLM_N_THREADS=4
LLM_N_GPU_LAYERS=0
LLM_MAX_CONCURRENCY=1

# ---------- 로깅 ----------
LOG_LEVEL=INFO
LOG_ROTATION=daily            # daily | size
LOG_RETENTION_DAYS=14
