<Application x:Class="WpfDesktopMvp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="AppBackground" Color="#0B0D10" />
    <SolidColorBrush x:Key="PanelBackground" Color="#15191F" />
    <SolidColorBrush x:Key="SoftPanelBackground" Color="#1D232B" />
    <SolidColorBrush x:Key="LineBrush" Color="#2C3440" />
    <SolidColorBrush x:Key="PrimaryText" Color="#F5F8FC" />
    <SolidColorBrush x:Key="SecondaryText" Color="#AAB5C4" />
    <SolidColorBrush x:Key="AccentBrush" Color="#8EC5FF" />
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="Background" Value="{StaticResource SoftPanelBackground}" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="Background" Value="#090B0E" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
      <Setter Property="CaretBrush" Value="{StaticResource PrimaryText}" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
  </Application.Resources>
</Application>
