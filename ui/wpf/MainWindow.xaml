<Window x:Class="WpfDesktopMvp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local AI WPF MVP"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="{StaticResource AppBackground}"
        Foreground="{StaticResource PrimaryText}">
  <Grid Margin="18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="320" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Padding="16"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="3. WPF"
                     FontSize="28"
                     FontWeight="Bold" />
          <TextBlock Margin="0,6,0,18"
                     Foreground="{StaticResource SecondaryText}"
                     TextWrapping="Wrap"
                     Text="Windows 전용 데스크톱 MVP. AI 호출은 ASP.NET API로 분리합니다." />

          <TextBlock Text="API 연결"
                     FontWeight="SemiBold" />
          <TextBox x:Name="ApiBaseUrlBox"
                   Margin="0,8,0,8"
                   Text="http://localhost:5088" />
          <Button x:Name="HealthButton"
                  Click="HealthButton_Click"
                  Content="상태 확인" />

          <TextBlock Margin="0,18,0,8"
                     Text="모델 선택"
                     FontWeight="SemiBold" />
          <ComboBox x:Name="ModelCombo"
                    IsEditable="True"
                    Text="llama3.2" />
          <Button Margin="0,8,0,0"
                  Click="LoadModelsButton_Click"
                  Content="모델 목록 새로고침" />

          <TextBlock Margin="0,18,0,8"
                     Text="파일 선택"
                     FontWeight="SemiBold" />
          <Button Click="SelectFileButton_Click"
                  Content="파일 선택" />
          <TextBlock x:Name="SelectedFileText"
                     Margin="0,8,0,0"
                     Foreground="{StaticResource SecondaryText}"
                     TextWrapping="Wrap"
                     Text="선택된 파일 없음" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="구조"
                     FontWeight="SemiBold" />
          <TextBlock Margin="0,8,0,0"
                     FontFamily="Cascadia Mono, Consolas"
                     Foreground="{StaticResource SecondaryText}"
                     Text="WPF&#x0a;  ↓&#x0a;HttpClient&#x0a;  ↓&#x0a;ASP.NET API&#x0a;  ↓&#x0a;Semantic Kernel" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1"
          Margin="14,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Margin="0,0,0,12"
              Padding="16"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Background="{StaticResource PanelBackground}">
        <StackPanel>
          <TextBlock Text="채팅창"
                     FontSize="22"
                     FontWeight="Bold" />
          <TextBlock Margin="0,5,0,0"
                     Foreground="{StaticResource SecondaryText}"
                     Text="WPF는 단순 클라이언트입니다. 메시지는 /api/chat으로 전송됩니다." />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Padding="14"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Background="{StaticResource PanelBackground}">
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl x:Name="ChatItems">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,10"
                        Padding="12"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SoftPanelBackground}">
                  <StackPanel>
                    <TextBlock Text="{Binding Role}"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding Content}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="2"
              Margin="0,12,0,0"
              Padding="12"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Background="{StaticResource PanelBackground}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="104" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="PromptBox"
                   Grid.Column="0"
                   MinHeight="74"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Text="WPF에서 ASP.NET API를 통해 응답해주세요." />
          <Button x:Name="SendButton"
                  Grid.Column="1"
                  Margin="10,0,0,0"
                  Click="SendButton_Click"
                  Content="전송" />
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Padding="16"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Background="{StaticResource PanelBackground}">
        <StackPanel>
          <TextBlock Text="설정창"
                     FontSize="22"
                     FontWeight="Bold" />

          <TextBlock Margin="0,14,0,8"
                     Text="NAS 경로 설정"
                     FontWeight="SemiBold" />
          <TextBox x:Name="NasPathBox"
                   Text="\\NAS\local-ai" />
          <Button Margin="0,8,0,0"
                  Click="SaveSettingsButton_Click"
                  Content="설정 저장" />

          <TextBlock Margin="0,16,0,8"
                     Text="빠른 작업"
                     FontWeight="SemiBold" />
          <Button Click="NewSessionButton_Click"
                  Content="새 세션" />
          <Button Margin="0,8,0,0"
                  Click="ToolButton_Click"
                  Content="도구 실행: time" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Margin="0,14,0,0"
              Padding="14"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Background="{StaticResource PanelBackground}">
        <DockPanel LastChildFill="True">
          <TextBlock DockPanel.Dock="Top"
                     Margin="0,0,0,10"
                     Text="로그 뷰어"
                     FontSize="22"
                     FontWeight="Bold" />
          <ListBox x:Name="LogItems"
                   Background="#090B0E"
                   BorderBrush="{StaticResource LineBrush}"
                   Foreground="{StaticResource PrimaryText}" />
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
