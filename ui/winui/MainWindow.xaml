<Window
    x:Class="WinUiModernUi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Local AI WinUI">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="4. WinUI"
                       FontSize="34"
                       FontWeight="SemiBold" />
            <TextBlock Text="최신 Windows 10/11 스타일이 필요할 때 선택하는 UI 계층입니다."
                       Opacity="0.72" />
        </StackPanel>

        <muxc:NavigationView Grid.Row="1"
                             PaneDisplayMode="LeftCompact"
                             IsBackButtonVisible="Collapsed">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="채팅"
                                         Icon="Message"
                                         Tag="chat" />
                <muxc:NavigationViewItem Content="모델"
                                         Icon="Library"
                                         Tag="models" />
                <muxc:NavigationViewItem Content="파일"
                                         Icon="OpenFile"
                                         Tag="files" />
                <muxc:NavigationViewItem Content="로그"
                                         Icon="Document"
                                         Tag="logs" />
            </muxc:NavigationView.MenuItems>

            <Grid Padding="20" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <InfoBar Title="권장 구조"
                         Message="WinUI -> HttpClient -> ASP.NET API -> Semantic Kernel"
                         IsOpen="True"
                         Severity="Informational" />

                <ListView Grid.Row="1"
                          x:Name="ChatList" />

                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptBox"
                             PlaceholderText="ASP.NET API로 보낼 메시지" />
                    <Button Grid.Column="1"
                            Content="전송" />
                </Grid>
            </Grid>
        </muxc:NavigationView>
    </Grid>
</Window>
